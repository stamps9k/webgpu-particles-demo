    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^16.4.7",
    "nodemon": "^3.1.9",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  },
  
  "dependencies": {
    "better-sqlite3": "^12.9.0",
