  "type": "module",
  "main": "server.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "vite --config config/vite.config.ts",
    "build": "tsc --project config/tsconfig.server.json --noEmit && vite --config config/vite.config.ts build && tsup --config config/tsup.config.ts",
